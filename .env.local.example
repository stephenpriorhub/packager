BRAIN_GITHUB_REPO=stephenpriorhub/brain
BRAIN_DIR=/Users/stephenprior/github/brain   # local dev fallback only

# ── Promo Analyzer (brief extraction + RAG training data) ───────────────────
PROMO_ANALYZER_URL=https://analyzer.oxfordhub.app

# ── Storage ─────────────────────────────────────────────────────────────────
DATA_DIR=./data                # Railway mounts a volume here in production
