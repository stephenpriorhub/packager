# ── Claude ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OxfordHub identity ──────────────────────────────────────────────────────
HUB_URL=https://oxfordhub.app
HUB_API_TOKEN=                 # service-to-service token (calls to the analyzer)

# ── Brain vault (guides, guru voices, claims principles) ────────────────────
